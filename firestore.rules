rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ma8138498@gmail.com" && request.auth.token.email_verified == true));
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/trades/{tradeId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // Allow reading all trades for global analysis (anonymized)
    match /{path=**}/trades/{tradeId} {
      allow read: if isAuthenticated();
    }

    match /global_strategies/{strategyId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
