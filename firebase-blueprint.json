{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A recorded trading signal and its outcome.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who took the trade." },
        "asset": { "type": "string", "description": "The trading asset." },
        "signal": { "type": "string", "enum": ["BUY", "SELL", "NEUTRAL"], "description": "BUY, SELL, or NEUTRAL." },
        "timestamp": { "type": "number", "description": "When the signal was generated." },
        "outcome": { "type": "string", "enum": ["Win", "Loss", "No Trade", "Pending"], "description": "The result of the trade." },
        "notes": { "type": "string", "description": "User notes about the trade." },
        "signalData": { "type": "object", "description": "The full original signal data." }
      },
      "required": ["uid", "asset", "signal", "timestamp", "outcome"]
    },
    "GlobalStrategy": {
      "title": "GlobalStrategy",
      "description": "A strategy or rule learned from analyzing aggregated trade data.",
      "type": "object",
      "properties": {
        "rule": { "type": "string", "description": "The learned trading rule." },
        "confidence": { "type": "number", "description": "AI confidence in this rule (0-100)." },
        "sourceCount": { "type": "number", "description": "Number of trades analyzed to derive this rule." },
        "timestamp": { "type": "number", "description": "When the rule was generated." }
      },
      "required": ["rule", "timestamp"]
    },
    "AdminSettings": {
      "title": "AdminSettings",
      "description": "Global system settings only manageable by admins.",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean", "description": "Whether the app is in maintenance mode." },
        "chatLocked": { "type": "boolean", "description": "Whether the chat feature is locked." },
        "broadcastMessage": { "type": "string", "description": "A message to show to all users." },
        "updatedAt": { "type": "number", "description": "Last update timestamp." }
      }
    },
    "User": {
      "title": "User",
      "description": "User metadata and access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "analysisCount": { "type": "number" },
        "isRevoked": { "type": "boolean" },
        "access": {
          "type": "object",
          "properties": {
            "autoTrade": { "type": "string", "enum": ["locked", "pending", "granted"] },
            "products": { "type": "string", "enum": ["locked", "pending", "granted"] }
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile and access data."
    },
    "/users/{uid}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of trades for a specific user."
    },
    "/global_strategies/{strategyId}": {
      "schema": "GlobalStrategy",
      "description": "Collection of strategies learned from all users' data."
    },
    "/admin_settings/{settingId}": {
      "schema": "AdminSettings",
      "description": "Global system settings."
    }
  }
}
