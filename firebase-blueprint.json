{
  "entities": {
    "User": {
      "title": "User",
      "description": "User metadata and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "analysisCount": { "type": "integer" },
        "isRevoked": { "type": "boolean" },
        "access": {
          "type": "object",
          "properties": {
            "autoTrade": { "type": "string", "enum": ["locked", "pending", "granted"] },
            "products": { "type": "string", "enum": ["locked", "pending", "granted"] },
            "sniperLiveTrade": { "type": "string", "enum": ["locked", "pending", "granted"] }
          }
        },
        "mt5Credentials": {
          "type": "object",
          "properties": {
            "server": { "type": "string" },
            "login": { "type": "string" },
            "password": { "type": "string", "description": "Encrypted password" }
          }
        },
        "createdAt": { "type": "integer" }
      },
      "required": ["uid", "email", "role", "analysisCount", "access", "createdAt"]
    },
    "Signal": {
      "title": "Signal",
      "description": "Trading signal generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "integer" },
        "asset": { "type": "string" },
        "timeframe": { "type": "string" },
        "signal": { "type": "string", "enum": ["BUY", "SELL", "NEUTRAL"] },
        "confidence": { "type": "number" },
        "entryPoints": { "type": "array", "items": { "type": "number" } },
        "entryType": { "type": "string" },
        "stopLoss": { "type": "number" },
        "takeProfits": { "type": "array", "items": { "type": "number" } },
        "reasoning": { "type": "array", "items": { "type": "string" } },
        "marketStory": { "type": "string" }
      },
      "required": ["id", "timestamp", "asset", "signal", "confidence"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A trade execution record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "asset": { "type": "string" },
        "signal": { "type": "string", "enum": ["BUY", "SELL", "NEUTRAL"] },
        "timestamp": { "type": "integer" },
        "outcome": { "type": "string", "enum": ["Win", "Loss", "No Trade", "Pending"] },
        "notes": { "type": "string" }
      },
      "required": ["uid", "asset", "signal", "timestamp", "outcome"]
    },
    "AccountSync": {
      "title": "AccountSync",
      "description": "Real-time account data from MT5",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "profit": { "type": "number" },
        "drawdown": { "type": "number" },
        "timestamp": { "type": "integer" }
      },
      "required": ["balance", "equity", "profit", "drawdown", "timestamp"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "System broadcast message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "integer" },
        "active": { "type": "boolean" }
      },
      "required": ["message", "timestamp", "active"]
    },
    "AdminSettings": {
      "title": "AdminSettings",
      "description": "Global system settings",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean" },
        "chatLocked": { "type": "boolean" },
        "sniperLocked": { "type": "boolean" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["maintenanceMode", "chatLocked", "sniperLocked", "updatedAt"]
    },
    "GlobalStrategy": {
      "title": "GlobalStrategy",
      "description": "AI-learned global trading strategy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rule": { "type": "string" },
        "timestamp": { "type": "integer" },
        "sourceCount": { "type": "integer" },
        "confidence": { "type": "number" }
      },
      "required": ["rule", "timestamp", "sourceCount", "confidence"]
    },
    "AutoMLStrategy": {
      "title": "AutoMLStrategy",
      "description": "A strategy learned by the Auto ML process",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "string", "description": "The actual strategy logic/rules" },
        "timestamp": { "type": "integer" },
        "performance": { "type": "number", "description": "Predicted or backtested performance" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "description", "rules", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings"
    },
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Public or shared signals"
    },
    "/users/{userId}/sync/account": {
      "schema": "AccountSync",
      "description": "MT5 account synchronization data"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "User's trade history"
    },
    "/broadcasts/{broadcastId}": {
      "schema": "Broadcast",
      "description": "System-wide broadcast messages"
    },
    "/admin_settings/{settingId}": {
      "schema": "AdminSettings",
      "description": "Global system settings"
    },
    "/global_strategies/{strategyId}": {
      "schema": "GlobalStrategy",
      "description": "AI-learned global trading strategies"
    },
    "/auto_ml_strategies/{strategyId}": {
      "schema": "AutoMLStrategy",
      "description": "Collection of strategies learned by Auto ML"
    }
  }
}
